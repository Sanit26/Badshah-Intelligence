# ─── Badshah Intelligence — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Internet Computer / ICP (only needed for local ICP dev with DFX) ──────────
# Leave blank when running in standalone frontend-only mode.
DFX_NETWORK=local
CANISTER_ID_BACKEND=
CANISTER_ID_FRONTEND=

# ── Internet Identity URL ─────────────────────────────────────────────────────
# Production: https://identity.internetcomputer.org/
# Local DFX:  http://rdmx6-jaaaa-aaaaa-aaadq-cai.localhost:8081/
II_URL=https://identity.internetcomputer.org/

# ── Storage Gateway (Caffeine AI blob storage) ────────────────────────────────
STORAGE_GATEWAY_URL=https://blob.caffeine.ai
